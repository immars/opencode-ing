# OpenCode-ing Agent 配置
# 复制此文件为 agent.yaml 并填写配置
# cp config/agent.yaml.example config/agent.yaml

# 飞书配置 (必填)
feishu:
  app_id: ""        # 飞书应用 ID (从飞书开放平台获取)
  app_secret: ""    # 飞书应用密钥

# OpenCode 配置 (必填)
opencode:
  api_key: ""       # OpenCode API Key
  model: "claude-sonnet-4-20250514"  # LLM 模型

# Agent 配置
agent:
  name: "Assistant"       # Agent 显示名称
  trigger: "@Assistant"   # 飞书消息触发词

# 分组配置
groups:
  main: "main"    # 主分组目录名
